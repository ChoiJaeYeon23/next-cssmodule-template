{
  "name": "gnapse_web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start:dev": "env-cmd -f .env.development next dev --turbopack --port 3000",
    "start:prod": "env-cmd -f .env.production next dev --turbopack --port 3000",
    "start:local": "env-cmd -f .env.local next dev --turbopack --port 3000",
    "build:dev": "env-cmd -f .env.development next build",
    "build:prod": "env-cmd -f .env.production next build",
    "build:local": "env-cmd -f .env.local next build",
    "host:dev": "yarn build:dev && env-cmd -f .env.development next start --port 3000",
    "host:prod": "yarn build:prod && env-cmd -f .env.production next start --port 3000",
    "host:local": "yarn build:local && env-cmd -f .env.local next start --port 3000",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "env-cmd": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "typescript": "^5"
  }
}
